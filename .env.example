APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Twilio (WhatsApp) — optional; registration welcome uses these when set
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Sender: whatsapp:+… or plain +E.164 (app adds whatsapp: if missing)
# TWILIO_WHATSAPP_FROM="+14155238886"
# Optional approved WhatsApp template SID (for business-initiated messaging outside session window)
# TWILIO_WHATSAPP_TEMPLATE_SID=
# Template variable slot that will receive the bilingual message body (default: 1)
# TWILIO_WHATSAPP_TEMPLATE_BODY_VARIABLE=1
# If template send fails, retry once with plain body
# TWILIO_WHATSAPP_TEMPLATE_FALLBACK_TO_BODY=true
# TWILIO_REGISTRATION_WELCOME_WHATSAPP_ENABLED=true
# TWILIO_REQUEST_SUBMITTED_WHATSAPP_ENABLED=true
# TWILIO_CLIENT_STAGE_WHATSAPP_ENABLED=true
# TWILIO_REGISTRATION_LOOKUP_LINE_TYPE=false
# BRAND_NAME_EN="Nofa Cast"
# BRAND_NAME_AR="نوفا كاست"

# SEO (optional — defaults exist in config/seo.php)
# APP_META_DESCRIPTION=
# APP_META_KEYWORDS=
# APP_OG_IMAGE=https://example.com/og-image.jpg
# APP_ROBOTS=index, follow
# APP_THEME_COLOR=#4f46e5

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

ADMIN_NAME="System Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
ADMIN_PHONE=90000000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: only for `npm run dev` when the Vite dev server (e.g. :5173) calls Laravel on another origin.
# Omit or leave unset when running `npm run build` for production — production uses the site origin automatically.
# VITE_API_BASE_URL=http://127.0.0.1:8000
